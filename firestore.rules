rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────
    // Helper functions
    // ──────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isSupervisor() {
      return isAuthenticated() && getUserData().role == 'supervisor';
    }

    function isViewer() {
      return isAuthenticated() && getUserData().role == 'viewer';
    }

    function isApproved() {
      return getUserData().status == 'approved';
    }

    function isSupervisorOf(userId) {
      let targetUser = get(/databases/$(database)/documents/users/$(userId)).data;
      return targetUser.supervisorId == request.auth.uid;
    }

    // ──────────────────────────────────────────────────
    // Users collection
    // ──────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can read their own profile
      // Supervisors can read their team members
      // Admins can read all
      // Viewers can read all (read-only)
      allow read: if (isAuthenticated() && (
        isOwner(userId) ||
        isAdmin() ||
        isViewer() ||
        isSupervisorOf(userId)
      )) || (
        resource.data.role == 'supervisor'
      );

      // Users can create their own document during registration
      allow create: if isAuthenticated() && isOwner(userId) &&
        request.resource.data.uid == userId &&
        request.resource.data.role in ['user', 'supervisor', 'viewer'] &&
        request.resource.data.status == 'pending';

      // Users can update their own displayName, phone
      // Supervisors can update their team members' status
      // Admins can update anything
      allow update: if isAuthenticated() && (
        (isOwner(userId) && onlyUpdatedFields(['displayName', 'phone', 'updatedAt'])) ||
        isAdmin() ||
        (isSupervisor() && isSupervisorOf(userId))
      );

      // No hard deletes — soft delete only (status = 'disabled')
      allow delete: if false;
    }

    // ──────────────────────────────────────────────────
    // Products collection (global product master)
    // ──────────────────────────────────────────────────
    match /products/{productId} {
      // All authenticated users can read products
      allow read: if isAuthenticated();

      // Only admins can create/update/delete products
      allow create, update: if isAdmin();
      allow delete: if false; // Soft delete via isActive flag
    }

    // ──────────────────────────────────────────────────
    // Supervisor Products (which products are active for a supervisor's team)
    // ──────────────────────────────────────────────────
    match /supervisorProducts/{supervisorId} {
      allow read: if isAuthenticated();

      // Supervisors can manage their own product selection
      // Admins can manage any
      allow write: if isAuthenticated() && (
        isOwner(supervisorId) ||
        isAdmin()
      );
    }

    // ──────────────────────────────────────────────────
    // Monthly Plans
    // Document ID format: {userId}_{YYYY-MM}
    // ──────────────────────────────────────────────────
    match /monthlyPlans/{planId} {
      // Users can read their own plans
      // Supervisors can read their team members' plans
      // Admins and viewers can read all
      allow read: if isAuthenticated() && (
        resource == null ||
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        isViewer() ||
        (isSupervisor() && isSupervisorOf(resource.data.userId))
      );

      // Users can create their own plans
      // Supervisors can create plans for their team members
      // Admins can create plans for anyone
      allow create: if isAuthenticated() && isApproved() && (
        request.resource.data.userId == request.auth.uid ||
        isAdmin() ||
        (isSupervisor() && isSupervisorOf(request.resource.data.userId))
      );

      // Users can update their own plans
      // Supervisors can override team member plans
      // Admins can update any plan
      allow update: if isAuthenticated() && isApproved() && (
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        (isSupervisor() && isSupervisorOf(resource.data.userId))
      );

      allow delete: if false;
    }

    // ──────────────────────────────────────────────────
    // Daily Sales
    // Document ID format: {userId}_{YYYY-MM-DD}
    // ──────────────────────────────────────────────────
    match /dailySales/{salesId} {
      allow read: if isAuthenticated() && (
        resource == null ||
        resource.data.userId == request.auth.uid ||
        resource.data.supervisorId == request.auth.uid ||
        isAdmin() ||
        isViewer() ||
        (isSupervisor() && isSupervisorOf(resource.data.userId))
      );

      // Users can create/update their own daily sales
      allow create: if isAuthenticated() && isApproved() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if isAuthenticated() && isApproved() &&
        resource.data.userId == request.auth.uid;

      allow delete: if false;
    }

    // ──────────────────────────────────────────────────
    // Approvals
    // ──────────────────────────────────────────────────
    match /approvals/{approvalId} {
      // Users can read their own approval records
      // Supervisors can read approvals directed to them
      // Admins can read all
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.supervisorId == request.auth.uid ||
        isAdmin()
      );

      // Users can create approval requests during registration
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending';

      // Supervisors can process approvals directed to them
      // Admins can process any approval
      allow update: if isAuthenticated() && (
        (resource.data.supervisorId == request.auth.uid && isSupervisor()) ||
        isAdmin()
      );

      allow delete: if false;
    }

    // ──────────────────────────────────────────────────
    // Audit Logs (append-only)
    // ──────────────────────────────────────────────────
    match /auditLogs/{logId} {
      // Only admins can read audit logs
      allow read: if isAdmin();

      // Authenticated users can create logs (triggered by app actions)
      allow create: if isAuthenticated();

      // No updates or deletes
      allow update, delete: if false;
    }

    // ──────────────────────────────────────────────────
    // App Settings (global)
    // ──────────────────────────────────────────────────
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────────────
    // Mail Queue (for Trigger Email Extension)
    // ──────────────────────────────────────────────────
    match /mail/{mailId} {
      allow create: if isAuthenticated() && (isAdmin() || isSupervisor());
      allow read, update, delete: if false;
    }

    // ──────────────────────────────────────────────────
    // Helper: check only specified fields were updated
    // ──────────────────────────────────────────────────
    function onlyUpdatedFields(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }
  }
}
